<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CadernoReceitas.Views.ResultadoQuizPage"
             Title="Resultado">
    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="14">
            <Frame Style="{StaticResource CardFrame}" BackgroundColor="#0F766E">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding Modo}" TextColor="#CCFBF1" FontAttributes="Bold" />
                    <Label Text="{Binding Score, StringFormat='{0}%'}" FontSize="56" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Pontuacao final" TextColor="#CCFBF1" />
                </VerticalStackLayout>
            </Frame>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Frame Style="{StaticResource CardFrame}"><VerticalStackLayout><Label Text="{Binding Acertos}" Style="{StaticResource PageTitle}" /><Label Text="Acertos" Style="{StaticResource MutedText}" /></VerticalStackLayout></Frame>
                <Frame Grid.Column="1" Style="{StaticResource CardFrame}"><VerticalStackLayout><Label Text="{Binding Erros}" Style="{StaticResource PageTitle}" /><Label Text="Erros" Style="{StaticResource MutedText}" /></VerticalStackLayout></Frame>
            </Grid>
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout>
                    <Label Text="{Binding Total, StringFormat='Total de perguntas: {0}'}" Style="{StaticResource SectionTitle}" />
                </VerticalStackLayout>
            </Frame>
            <Button Text="Fazer novamente" Command="{Binding AgainCommand}" />
            <Button Text="Voltar para home" BackgroundColor="{StaticResource Muted}" Command="{Binding BackHomeCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
