<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CadernoReceitas.Views.HomePage"
             Title="Home">
    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="14">
            <Frame Style="{StaticResource CardFrame}" BackgroundColor="#0F766E">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Caderno de Receitas" FontSize="32" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Treine equipes de restaurante com receitas, ingredientes e provas offline." TextColor="#CCFBF1" />
                    <Button Text="Iniciar quiz" BackgroundColor="#F97316" TextColor="#17212B" Command="{Binding GoToQuizCommand}" />
                </VerticalStackLayout>
            </Frame>
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                <Frame Style="{StaticResource CardFrame}"><VerticalStackLayout><Label Text="{Binding Receitas}" Style="{StaticResource PageTitle}" /><Label Text="Receitas" Style="{StaticResource MutedText}" /></VerticalStackLayout></Frame>
                <Frame Grid.Column="1" Style="{StaticResource CardFrame}"><VerticalStackLayout><Label Text="{Binding Pratos}" Style="{StaticResource PageTitle}" /><Label Text="Pratos" Style="{StaticResource MutedText}" /></VerticalStackLayout></Frame>
                <Frame Grid.Row="1" Style="{StaticResource CardFrame}"><VerticalStackLayout><Label Text="{Binding Restaurantes}" Style="{StaticResource PageTitle}" /><Label Text="Restaurantes" Style="{StaticResource MutedText}" /></VerticalStackLayout></Frame>
                <Frame Grid.Row="1" Grid.Column="1" Style="{StaticResource CardFrame}"><VerticalStackLayout><Label Text="{Binding Pracas}" Style="{StaticResource PageTitle}" /><Label Text="Pracas" Style="{StaticResource MutedText}" /></VerticalStackLayout></Frame>
                <Frame Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource CardFrame}"><VerticalStackLayout><Label Text="{Binding Ingredientes}" Style="{StaticResource PageTitle}" /><Label Text="Ingredientes cadastrados" Style="{StaticResource MutedText}" /></VerticalStackLayout></Frame>
            </Grid>
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Atualizacoes" Style="{StaticResource SectionTitle}" />
                    <Label Text="{Binding UpdateStatus}" Style="{StaticResource MutedText}" />
                    <Button Text="Verificar update" Command="{Binding CheckUpdatesCommand}" />
                </VerticalStackLayout>
            </Frame>
            <Label Text="Historico recente" Style="{StaticResource SectionTitle}" />
            <CollectionView ItemsSource="{Binding Historico}">
                <CollectionView.EmptyView><Label Text="Nenhuma prova realizada ainda." Style="{StaticResource MutedText}" /></CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Style="{StaticResource CardFrame}">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Modo}" FontAttributes="Bold" />
                                    <Label Text="{Binding RealizadoEm, StringFormat='{0:dd/MM/yyyy HH:mm}'}" Style="{StaticResource MutedText}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding Pontuacao, StringFormat='{0:0.#}%'}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Secondary}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
