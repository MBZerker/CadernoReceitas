<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CadernoReceitas.Views.QuizPage"
             x:Name="Page"
             Title="Quiz">
    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="14">
            <Frame Style="{StaticResource CardFrame}" BackgroundColor="#FFF7ED">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Quiz de aprendizagem" Style="{StaticResource PageTitle}" />
                    <Label Text="Perguntas aleatorias sobre preparo e ingredientes." Style="{StaticResource MutedText}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Quiz rapido" Command="{Binding StartCommand}" CommandParameter="Quiz" />
                        <Button Grid.Column="1" Text="Modo prova" BackgroundColor="#F97316" TextColor="#17212B" Command="{Binding StartCommand}" CommandParameter="Prova" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Mode}" Style="{StaticResource SectionTitle}" />
                        <Label Grid.Column="1" Text="{Binding ProgressText}" TextColor="{StaticResource Secondary}" FontAttributes="Bold" />
                    </Grid>
                    <Label Text="{Binding QuestionText}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Ink}" />
                    <Label Text="{Binding Feedback}" Style="{StaticResource MutedText}" />
                    <CollectionView ItemsSource="{Binding Alternativas}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Button Text="{Binding .}" Margin="0,5" HorizontalOptions="Fill" Command="{Binding BindingContext.AnswerCommand, Source={x:Reference Page}}" CommandParameter="{Binding .}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
