<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CadernoReceitas.Views.ReceitasPage"
             x:Name="Page"
             Title="Receitas">
    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="12">
            <Label Text="Receitas" Style="{StaticResource PageTitle}" />
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Picker Title="Prato" ItemsSource="{Binding Pratos}" ItemDisplayBinding="{Binding Nome}" SelectedItem="{Binding SelectedPrato}" />
                    <Editor Placeholder="Modo de preparo" AutoSize="TextChanges" HeightRequest="120" Text="{Binding ModoPreparo}" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Button Text="Salvar" Command="{Binding SaveCommand}" />
                        <Button Grid.Column="1" Text="Limpar" BackgroundColor="{StaticResource Muted}" Command="{Binding ClearCommand}" />
                        <Button Grid.Column="2" Text="Excluir" BackgroundColor="#DC2626" Command="{Binding DeleteCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Ingredientes da receita selecionada" Style="{StaticResource SectionTitle}" />
                    <Entry Placeholder="Ingrediente" Text="{Binding IngredienteNome}" />
                    <Entry Placeholder="Quantidade" Text="{Binding IngredienteQuantidade}" />
                    <Button Text="Adicionar ingrediente" Command="{Binding AddIngredienteCommand}" />
                    <CollectionView ItemsSource="{Binding Ingredientes}">
                        <CollectionView.EmptyView><Label Text="Salve ou selecione uma receita para adicionar ingredientes." Style="{StaticResource MutedText}" /></CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Nome}" FontAttributes="Bold" />
                                        <Label Text="{Binding Quantidade}" Style="{StaticResource MutedText}" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="1" Text="Excluir" BackgroundColor="#DC2626" Command="{Binding BindingContext.DeleteIngredienteCommand, Source={x:Reference Page}}" CommandParameter="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Label Text="Receitas cadastradas" Style="{StaticResource SectionTitle}" />
            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.EmptyView><Label Text="Cadastre pratos e registre suas receitas." Style="{StaticResource MutedText}" /></CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Style="{StaticResource CardFrame}">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding PratoNome}" FontSize="18" FontAttributes="Bold" />
                                    <Label Text="{Binding ModoPreparo}" MaxLines="2" LineBreakMode="TailTruncation" Style="{StaticResource MutedText}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Editar" Command="{Binding BindingContext.SelectCommand, Source={x:Reference Page}}" CommandParameter="{Binding .}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
