<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CadernoReceitas.Views.CadernoPage"
             x:Name="Page"
             Title="{Binding NomeCaderno}">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <Frame Style="{StaticResource CardFrame}">
                <Grid ColumnDefinitions="64,*" ColumnSpacing="14">
                    <Image Source="icon_notebook" HeightRequest="56" WidthRequest="56" />
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="{Binding NomeCaderno}" Style="{StaticResource PageTitle}" />
                        <Label Text="{Binding DescricaoCaderno}" Style="{StaticResource MutedText}" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Nova receita" Style="{StaticResource SectionTitle}" />
                    <Entry Placeholder="Nome da receita" Text="{Binding NovaReceitaNome}" />
                    <Editor Placeholder="Modo de preparo inicial" AutoSize="TextChanges" HeightRequest="92" Text="{Binding NovaReceitaPreparo}" />
                    <ImageButton Style="{StaticResource IconOnlyButton}" Source="icon_add" Command="{Binding NovaReceitaCommand}" SemanticProperties.Description="Adicionar receita" />
                </VerticalStackLayout>
            </Frame>

            <CollectionView ItemsSource="{Binding Receitas}">
                <CollectionView.EmptyView>
                    <Frame Style="{StaticResource CardFrame}">
                        <Label Text="Adicione receitas a este caderno." Style="{StaticResource MutedText}" />
                    </Frame>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Style="{StaticResource CardFrame}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.AbrirReceitaCommand, Source={x:Reference Page}}" CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="58,*" ColumnSpacing="14">
                                <Image Source="icon_recipe" HeightRequest="50" WidthRequest="50" />
                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label Text="{Binding Nome}" FontSize="19" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#17212B, Dark=#F8FAFC}" />
                                    <Label Text="{Binding ModoPreparo}" MaxLines="2" LineBreakMode="TailTruncation" Style="{StaticResource MutedText}" />
                                    <Label Text="{Binding TotalIngredientes, StringFormat='{0} ingredientes'}" TextColor="{AppThemeBinding Light=#B83216, Dark=#FFE7B0}" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
