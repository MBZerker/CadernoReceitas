<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CadernoReceitas.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CadernoReceitas.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="Caderno de Receitas">

    <TabBar>
        <ShellContent Title="Home" Route="home" ContentTemplate="{DataTemplate views:HomePage}" />
        <ShellContent Title="Restaurantes" Route="restaurantes" ContentTemplate="{DataTemplate views:RestaurantesPage}" />
        <ShellContent Title="Pracas" Route="pracas" ContentTemplate="{DataTemplate views:PracasPage}" />
        <ShellContent Title="Pratos" Route="pratos" ContentTemplate="{DataTemplate views:PratosPage}" />
        <ShellContent Title="Receitas" Route="receitas" ContentTemplate="{DataTemplate views:ReceitasPage}" />
        <ShellContent Title="Quiz" Route="quiz" ContentTemplate="{DataTemplate views:QuizPage}" />
    </TabBar>

</Shell>
